# Direct Gemini API key (fallback if Azure Key Vault is unavailable)
GEMINI_API_KEY=your_gemini_api_key_here

# Azure Key Vault configuration (optional, preferred)
# The server will fetch GEMINI_SECRET_NAME from this vault
AZURE_KEY_VAULT_URL=https://dp-kv-deliverypilot.vault.azure.net
GEMINI_SECRET_NAME=GEMINI-API-KEY-PRIMARY

# Server
PORT=3000
